# Configuração pública — pode ser versionada no GitHub.
# Segredos (chaves de API, WEB_SECRET_KEY, etc.) ficam em .env (ignorado pelo git)

WEB_VERBOSIDADE=2
WEB_COOKIE_SECURE=1
WEB_MAX_USD_PER_USER_PER_MONTH=5
WEB_OUTPUT_RETENTION_HOURS=2
WEB_OUTPUT_MAX_GB=2
WEB_MAX_RUNNING_JOBS=8
WEB_THREADS=4

# Configurações dos providers e modelos (LLMs)
WEB_LLM_PROVIDER_OPTIONS=iaedu,anthropic
WEB_LLM_MODEL_OPTIONS_JSON={"iaedu":["gpt-4o"],"anthropic":["claude-sonnet-4-6","claude-opus-4-6"]}
WEB_FREE_LLM_PROVIDERS=iaedu
LLM_PRICING_JSON={"gpt-4o":[0.0,0.0],"claude-opus-4-6":[5,25],"claude-sonnet-4-6":[3,15]}

# Opção selecionada por omissão na combobox da Web (provider::modelo)
WEB_LLM_DEFAULT_CHOICE=anthropic::claude-opus-4-6

# Modelos default por provider
IAEDU_MODELO_ANALISE=gpt-4o
ANTHROPIC_MODELO_ANALISE=claude-opus-4-6
ANTHROPIC_MODELO_CONDENSACAO=claude-sonnet-4-6

# Autenticação Microsoft OAuth (opcional; deixar vazio para desativar)
# Registar app em portal.azure.com → Azure Active Directory → App registrations
# Redirect URI a configurar: https://ce.uc-reports.com/login/microsoft/callback
MS_TENANT=up.pt
MS_CLIENT_ID=
MS_REDIRECT_URI=https://ce.uc-reports.com/login/microsoft/callback
# MS_CLIENT_SECRET vai em .env (segredo)

# Sessão SIGARRA do servidor (para autenticação Microsoft e email OTP; opcional)
# SIGARRA_SERVER_LOGIN e SIGARRA_SERVER_PASSWORD vão em .env (segredos)

# Autenticação por email OTP via Resend (opcional; deixar vazio para desativar)
# Só aceita emails no formato upNNNNNN@up.pt
# RESEND_API_KEY vai em .env (segredo)
RESEND_FROM=noreply@ce.uc-reports.com

# Tolerância a falhas na chamada ao LLM
LLM_MAX_RETRIES=3
LLM_RETRY_BASE_SECONDS=2
LLM_RETRY_MAX_SECONDS=20
